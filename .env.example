# ============================================================
# InsightMesh AI — Environment Variables (TEMPLATE)
# ============================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git — it's gitignored.
# ============================================================

# ============================================================
# LLM BRAIN (required) — picks the model used for all analysis
# ============================================================
# Resolution order in code:
#   LLM_PROVIDER=openai  → OpenAI is PRIMARY (Ollama is fallback)
#   LLM_PROVIDER=ollama  → Ollama is PRIMARY (forces local)
#   LLM_PROVIDER unset   → legacy free-first (Ollama if reachable, else OpenAI)
# For production / recruiter demos, use OpenAI — no local Ollama to run.
LLM_PROVIDER=openai

# Generic model name. Takes precedence over OPENAI_MODEL when set.
LLM_MODEL=gpt-4o-mini

# ---- OpenAI (REQUIRED when LLM_PROVIDER=openai) ----
# Used for: per-review understanding, phrase extraction, action items,
# solution refinement, executive summary, multi-agent debate.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Ollama (only used if LLM_PROVIDER=ollama, or as free-first fallback) ----
# Install: https://ollama.com/download  then: ollama pull qwen2.5:7b
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_TIMEOUT_SEC=60

# ---- Per-run LLM budget (PERMANENT — see CLAUDE.md) ----
# Caps the slow per-review "understanding" LLM call count per analysis run.
# 15 keeps Quick/Balanced runs fast and cheap. 0 = uncapped (slow + expensive).
MAX_UNDERSTANDING_PER_RUN=15

# ---- YouTube Data API v3 (required for YouTube scraping) ----
# Google Cloud Console → APIs & Services → Credentials
YOUTUBE_API_KEY=

# ---- Reddit API (required for Reddit scraping) ----
# Create app at: https://www.reddit.com/prefs/apps  (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=insightmesh/0.1 by your_username

# Reddit username/password are OPTIONAL — only set if you need authenticated
# (write) access. For read-only scraping, leave blank. NEVER commit passwords.
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ============================================================
# Optional tunables (uncomment & override defaults as needed)
# ============================================================

# ---- Auth (opt-in API key) ----
# Leave UNSET for local dev (auth disabled — pass-through).
# Generate a strong key with: openssl rand -hex 32
# INSIGHTMESH_API_KEY=
# Or rotate multiple keys at once (comma-separated, no spaces):
# INSIGHTMESH_API_KEYS=key1,key2

# ---- Rate limiting (in-process, per-IP, fixed-window) ----
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_DEFAULT=120/minute
# RATE_LIMIT_PIPELINE=30/minute       # /run_pipeline + /run_pipeline/stream
# RATE_LIMIT_SCRAPE=60/minute         # /reviews/scrape/*
# RATE_LIMIT_ANALYZE=60/minute        # /reviews/analyze + /insightmesh/categorize
# RATE_LIMIT_EXPORT=60/minute         # /export/*, /understand/*, /forecast/*
# If you run behind a reverse proxy (nginx, ALB), set the proxy IP so we
# trust X-Forwarded-For only from it:
# RATE_LIMIT_TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# ---- Server ----
# BASE_URL=http://127.0.0.1:8000
# API_PREFIX=/api
# Restrict CORS to your real frontend origin(s) in production (NOT "*").
# Comma-separated, no spaces. Default is "*" (open) for local dev.
# CORS_ORIGINS=https://your-frontend.example.com
# LOG_LEVEL=INFO
# LOG_FORMAT=json                      # structured logs for prod ingestion

# ---- Filtering / strictness ----
# FILTER_STRICTNESS=normal           # low | normal | high | ultra
# STRICTNESS=ultra                   # analyzer default
# FILTER_MIN_LEN=6
# FILTER_MAX_LEN=1200
# FILTER_ALPHA_MIN=0.05
# FILTER_LANGS=en,es,fr,de,hi        # comma-separated ISO codes

# ---- Analyzer ----
# MAX_GPT_PER_REVIEW=12
# PHRASES_MODEL=gpt-3.5-turbo
# SKIP_PHRASE_EXTRACTION=0
# SKIP_ACTION_ITEMS=0
# ANALYZE_BATCH_MAX=40
# RAG_DOCS_DIRS=                     # comma-separated dirs for RAG grounding

# ---- Solutions / suggestions models ----
# SOLUTION_MODEL=gpt-3.5-turbo
# SUGGESTIONS_MODEL=gpt-4o-mini

# ---- Scraper limits (safety nets) ----
# YT_MAX_VIDEOS=2
# YT_MAX_COMMENTS=20
# YT_MAX_VIDEOS_CAP=10
# YT_MAX_COMMENTS_CAP=200
# YT_COMMENT_PAGES_CAP=3
# REDDIT_LIMIT=20
# REDDIT_LIMIT_CAP=200
# REDDIT_MAX_POSTS_PER_SUB=3
# REDDIT_BUDGET_SEC=5.0

# ---- CSV understanding ----
# GENERATE_PROFILE=1
# PROFILE_MAX_ROWS=5000

# ---- Pipeline ----
# USE_HTTP_ANALYZER=0
# USE_REDDIT_COMPACTOR=1
# LONG_BLOCK_CHARS=400
# MIN_TEXT_LEN=6
# DROP_NONALPHA_RATIO=0.95
# MIN_WORDS=3
# SKIP_ANALYZE=0                     # set 1 to debug pipeline without analyzer

# ---- Column guesser ----
# CG_SEMANTIC_THRESHOLD=0.60
# CG_NUMERIC_THRESHOLD=0.95
# CG_USE_SEMANTICS=1
