# Files NOT copied into Docker images (smaller builds, no leaked secrets)

# Secrets
.env
.env.*
!.env.example

# Git / VCS
.git/
.gitignore
.github/

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual envs (you do NOT want to copy your local venv into the image)
myenv/
venv/
env/
.venv/

# Node
node_modules/
insightmesh-fe/node_modules/
insightmesh-fe/dist/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Generated / scratch
DOWNLOADS/
backend/data/raw/*.csv
backend/data/raw/*.tsv
backend/data/raw/*.xlsx
backend/data/processed/*.html
backend/data/*.db
backend/data/*.sqlite*

# Notebooks
*.ipynb
.ipynb_checkpoints/

# Docker
docker-compose*.yml
Dockerfile*
.dockerignore

# Documentation builds
docs/_build/

# Logs
*.log
logs/
