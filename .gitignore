# ============================================================
# InsightMesh AI — root .gitignore
# ============================================================

# Secrets / env files — NEVER commit
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Virtual environments
myenv/
venv/
env/
.venv/
ENV/

# Node / frontend
node_modules/
insightmesh-fe/node_modules/
insightmesh-fe/dist/
insightmesh-fe/dist-ssr/
insightmesh-fe/.vite/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Data — user-uploaded CSVs and generated reports (may contain PII)
backend/data/raw/*.csv
backend/data/raw/*.tsv
backend/data/raw/*.xlsx
backend/data/processed/*.html
!backend/data/raw/.gitkeep
!backend/data/processed/.gitkeep

# Downloads scratch folder
DOWNLOADS/

# Model caches (HuggingFace, etc.)
.cache/
~/.cache/

# Notebooks
.ipynb_checkpoints/
*.ipynb

# DB files (for upcoming run-history feature)
*.db
*.sqlite
*.sqlite3
